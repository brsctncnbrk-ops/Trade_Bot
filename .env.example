# Calisma modu: backtest | testnet | live
# Varsayilan ve guvenli mod: backtest (API anahtari gerektirmez)
MODE=backtest

# Gercek Binance API anahtarlari (SADECE live mod icin, ASLA commit etmeyin!)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Spot Testnet API anahtarlari (https://testnet.binance.vision)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Islem ayarlari
BASE_CURRENCY=USDT
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAME=1h

# Risk yonetimi - testnet 100 USDT sanal kasa
INITIAL_BALANCE=100
MAX_CAPITAL_USDT=100
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_HOURLY_LOSS=0.02
MAX_OPEN_POSITIONS=1
MAX_DAILY_TRADES=5
MAX_NOTIONAL_PER_TRADE_USDT=10
MAX_TOTAL_OPEN_RISK_USDT=100
MAX_CONCURRENT_ORDERS=1
MAX_API_ERRORS=5

STOP_LOSS_PERCENT=0.02
STOP_ATR_MULTIPLIER=2.0
MIN_STOP_DISTANCE_PERCENT=0.003
MAX_STOP_DISTANCE_PERCENT=0.05
TAKE_PROFIT_PERCENT=0.04
MIN_RISK_REWARD=2.0
BREAK_EVEN_TRIGGER_R=1.0
TRAILING_STOP_ACTIVATION_R=2.0
TRAILING_STOP_ATR_MULTIPLIER=2.0

# Islem filtreleri
ENABLE_TRADE_FILTERS=true
MAX_SPREAD_PERCENT=0.10
MIN_VOLUME_USDT=100000
MIN_ATR_PERCENT=0.20
MAX_ATR_PERCENT=5.00
TREND_FILTER_ENABLED=true
TREND_EMA_PERIOD=200

# Emir guvenligi
ORDER_TYPE=LIMIT
OPEN_ORDER_TIMEOUT_SECONDS=60
STATE_FILE=state.json

# Canli islem guvenlik kilidi: live mod icin acikca "true" yapilmalidir
ALLOW_LIVE_TRADING=false

# Telegram bildirimleri (opsiyonel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
