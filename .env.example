# Calisma modu: backtest | testnet | live
# Varsayilan ve guvenli mod: backtest (API anahtari gerektirmez)
MODE=backtest

# Gercek Binance API anahtarlari (SADECE live mod icin, ASLA commit etmeyin!)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Spot Testnet API anahtarlari (https://testnet.binance.vision)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Islem ayarlari
BASE_CURRENCY=USDT
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAME=1h

# Risk yonetimi
INITIAL_BALANCE=1000
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_OPEN_POSITIONS=1
MAX_DAILY_TRADES=5

STOP_LOSS_PERCENT=0.02
TAKE_PROFIT_PERCENT=0.04

# Canli islem guvenlik kilidi: live mod icin acikca "true" yapilmalidir
ALLOW_LIVE_TRADING=false

# Telegram bildirimleri (opsiyonel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
